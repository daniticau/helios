# Helios — environment template. Copy to .env and fill in.

# Orthogonal SDK — primary integration
ORTHOGONAL_API_KEY=orth_live_your_key_here

# Anthropic — utility bill PDF parsing (Claude vision)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Backend config
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO
BACKEND_ALLOWED_ORIGINS=*

# Mode A/B behavior
ORTHOGONAL_TIMEOUT_SECONDS=18
ORTHOGONAL_PARALLELISM=10
CACHE_ENABLED=true
