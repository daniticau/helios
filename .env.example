# Helios — environment template. Copy to .env and fill in.

# Orthogonal SDK — primary integration
ORTHOGONAL_API_KEY=orth_live_your_key_here

# Anthropic — utility bill PDF parsing (Claude vision)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ElevenLabs — optional voice narration ("speak my result" button + demo video)
# Free tier (10k chars/month) is plenty for demo. See docs/ELEVENLABS.md.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Backend config
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO
BACKEND_ALLOWED_ORIGINS=*

# Mode A/B behavior
ORTHOGONAL_TIMEOUT_SECONDS=18
ORTHOGONAL_PARALLELISM=10
CACHE_ENABLED=true

# Supabase auth — optional. Required only when you want the web + mobile
# auth flows to actually work. Leave empty for pure anonymous demo mode.
# Get these from Supabase dashboard → Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Backend URL — consumed by the Next.js web app's /api/roi proxy.
# Dev: http://localhost:8000
# Prod: your Render URL, e.g. https://helios-backend.onrender.com
BACKEND_URL=http://localhost:8000
