# Helios — environment template. Copy to .env and fill in.

# Orthogonal SDK — primary integration
ORTHOGONAL_API_KEY=orth_live_your_key_here

# Anthropic — utility bill PDF parsing (Claude vision)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ElevenLabs — optional voice narration ("speak my result" button + demo video)
# Free tier (10k chars/month) is plenty for demo. See docs/ELEVENLABS.md.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Backend config
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO
BACKEND_ALLOWED_ORIGINS=*

# Mode A/B behavior
ORTHOGONAL_TIMEOUT_SECONDS=18
ORTHOGONAL_PARALLELISM=10
CACHE_ENABLED=true

# Supabase auth (NEW API key model — publishable + secret keys with
# asymmetric JWT signing). Backend verifies JWTs via JWKS — no shared
# secret needed. Leave empty for anonymous-only demo mode.
# See docs/DEPLOY.md.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Backend URL — consumed by the Next.js web app's /api/roi proxy.
# Dev: http://localhost:8000
# Prod: your App Runner URL, e.g. https://xxxxx.us-west-2.awsapprunner.com
BACKEND_URL=http://localhost:8000
