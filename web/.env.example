# Helios web — environment template. Copy to .env.local for local dev.
# Vercel: paste these into the dashboard env settings for production.

# Public Supabase anon key + project URL (safe to expose to browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-jwt...

# Backend URL — used server-side by /api/roi proxy route.
# Dev: http://localhost:8000
# Prod: your Render URL, e.g. https://helios-backend.onrender.com
BACKEND_URL=http://localhost:8000
