# Helios web — environment template. Copy to .env.local for local dev.
# Vercel: paste these into the dashboard env settings for production.

# Supabase publishable key + project URL. Safe to expose to browser —
# the publishable key is the new-format replacement for the legacy
# `anon` key (prefix `sb_publishable_`).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Backend URL — used server-side by /api/roi proxy route.
# Dev: http://localhost:8000
# Prod: your App Runner URL, e.g. https://xxxxx.us-west-2.awsapprunner.com
BACKEND_URL=http://localhost:8000
