{
  "expo": {
    "name": "Helios",
    "slug": "helios",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "helios",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.helios.app"
    },
    "android": {
      "package": "com.helios.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-notifications"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:8000"
    }
  }
}
